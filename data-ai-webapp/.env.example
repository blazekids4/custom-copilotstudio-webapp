# Azure AI Foundry
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4-1

# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000
