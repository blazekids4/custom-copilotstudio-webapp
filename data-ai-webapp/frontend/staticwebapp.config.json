{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["anonymous", "authenticated"]
    }
  ],
  "responseOverrides": {},
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "networking": {
    "allowedIpRanges": ["AnyIPAddress"]
  }
}
